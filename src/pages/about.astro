---
// About page — Cotton background, Noir text
import Layout from "../layouts/Layout.astro";
import Header from "../components/navigation/Header.astro";
import Footer from "../components/navigation/Footer.astro";
---

<Layout
  title="About"
  description="Ncheta Magazine — documenting African art narratives, from historical scholarship to the contemporary market."
>
  <Header />
  <main class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <!-- Breadcrumb -->
    <nav class="mb-8 font-inter text-xs text-noir/40 flex gap-2" aria-label="Breadcrumb">
      <a href="/" class=" transition-colors">Home</a>
      <span>/</span>
      <span class="text-noir/60">About</span>
    </nav>

    <h1 class="font-cinzel font-bold text-4xl md:text-5xl text-noir mb-3">About Ncheta</h1>
    <p class="font-inter text-base text-noir/50 mb-10 border-l-2 border-cherry pl-4">
      "Ncheta" means <em>remember</em> in Igbo — and that is our mission.
    </p>

    <div class="prose-content">
      <p>
        Ncheta Magazine is a digital publication dedicated to documenting African art narratives — from
        historical scholarship to the contemporary market. Founded by a team of writers, curators, and
        collectors across the continent and the diaspora, we cover the stories that shape how African art
        is understood, collected, and debated worldwide.
      </p>
      <p>
        We cover art news, academic research, exclusive interviews, collecting trends, African art history,
        exhibitions and fairs, galleries and museums, and awards. Our editorial standards are rooted in
        rigorous scholarship and cultural sensitivity — we do not treat African art as monolithic, and we
        resist the tendency to reduce the continent's enormous diversity of artistic practice to a single
        market narrative.
      </p>
      <h2>Our Editorial Pillars</h2>
      <ul>
        <li><strong>Art News</strong> — breaking developments in the African art world</li>
        <li><strong>Academia</strong> — peer-reviewed thinking and scholarly debate</li>
        <li><strong>Interviews</strong> — in-depth conversations with artists, curators, and collectors</li>
        <li><strong>Collecting Now</strong> — guidance and analysis for collectors at every level</li>
        <li><strong>African Art History</strong> — recovering the record</li>
        <li><strong>Exhibitions & Fairs</strong> — reviews and previews</li>
        <li><strong>Galleries & Museums</strong> — institutional coverage across the continent</li>
        <li><strong>Awards</strong> — celebrating artistic achievement</li>
      </ul>
      <h2>Contact</h2>
      <p>
        For editorial enquiries, press releases, or partnership proposals, please visit our
        <a href="/contact"> contact page</a> or write to <a href="mailto:editorial@ncheta.com">editorial@ncheta.com</a>.
      </p>
    </div>
  </main>
  <Footer />
</Layout>