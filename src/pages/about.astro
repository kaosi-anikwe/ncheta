---
// About page
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="About" description="Ncheta Magazine — documenting African art narratives.">
  <Header />
  <main class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h1 class="font-cinzel font-bold text-4xl md:text-5xl text-white mb-8">About Ncheta</h1>
    <div class="prose-content">
      <p>
        Ncheta Magazine is a digital publication dedicated to documenting African art narratives — from
        historical scholarship to the contemporary market. "Ncheta" means "remember" in Igbo, reflecting
        our commitment to preserving and amplifying the stories that shape African art discourse.
      </p>
      <p>
        We cover art news, academic research, exclusive interviews, collecting trends, African art history,
        exhibitions and fairs, galleries and museums, and awards. Our editorial team works with scholars,
        curators, and artists across the continent and the diaspora.
      </p>
    </div>
  </main>
  <Footer />
</Layout>