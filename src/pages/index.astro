        imageUrl: "https://images.unsplash.com/photo-1568097904979-f6e3f1c6a5d4?w=400&q=80",
        date: "2026-05-08",
      },
    ],
    text: [
      {
        title: "A guide to the best African art residencies accepting applications this year",
        category: "Resources",
        href: "/resources/art-residencies-2026",
        date: "2026-05-06",
        author: "Sade Johnson",
      },
      {
        title: "Luxury, craft, and identity: the new generation of African fashion and fine art crossovers",
        category: "Collecting Now",
        href: "/magazine/collecting-now/fashion-art-crossover",
        date: "2026-05-04",
        author: "Fatima Diallo",
      },
      {
        title: "Five African museums that are quietly building world-class permanent collections",
        category: "Galleries & Museums",
        href: "/magazine/galleries-museums/five-african-museums",
        date: "2026-05-02",
        author: "Chukwuemeka Osei",
      },
      {
        title: "The Zeitz MOCAA at five: how it changed Cape Town's cultural landscape",
        category: "Galleries & Museums",
        href: "/magazine/galleries-museums/zeitz-mocaa-five-years",
