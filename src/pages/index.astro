---
import Layout from "../layouts/Layout.astro";
import Header from "../components/navigation/Header.astro";
import Footer from "../components/navigation/Footer.astro";
import ArticleCard from "../components/cards/ArticleCard.astro";
import { getAllEditorials, getAllCategories, getNavigationSettings } from "../sanity/queries";
import type { Category, Article, NavigationSettings } from "../sanity/types";
import { urlFor } from "../sanity/image";

// Fetch Sanity articles, categories, and settings dynamically
let sanityArticles: Article[] = [];
let sanityCategories: Category[] = [];
let navSettings: NavigationSettings | null = null;
try {
  sanityArticles = await getAllEditorials();
  sanityCategories = await getAllCategories();
  navSettings = await getNavigationSettings();
} catch (err) {
  console.warn("Failed to fetch data from Sanity, using fallback.", err);
}

// Configurable limits from Sanity or fallbacks
const MAX_HOMEPAGE_CATEGORIES = navSettings?.maxHomepageCategories || 5;
const MAX_ARTICLES_PER_CATEGORY = navSettings?.maxArticlesPerCategory || 9;

// ── Static placeholder data (fallback if Sanity is empty) ──
const fallbackSections = [
  {
    title: "Latest",
    slug: "art-news",
    subCategories: [
      { name: "Auctions", slug: "auctions" },
    ],
    hero: {
      title: "President and general manager of Sotheby's on revitalising the auction house for a new generation of collectors",
      excerpt: "In a wide-ranging conversation, the new leadership team outlines a bold plan to remake the storied auction house for the digital era.",
      category: "Art News",
      href: "/magazine/art-news/sothebys-new-era",
      imageUrl: "https://images.unsplash.com/photo-1578926375605-eaf7559b1458?w=900&q=80",
      date: "2026-07-01",
      author: "Emeka Okafor",
    },
    small: [
      {
        title: "Bonhams set to sell major collection of West African bronze sculptures",
        category: "Art Market",
        href: "/magazine/art-news/bonhams-west-african",
        imageUrl: "https://images.unsplash.com/photo-1603039155534-f4a5d97be7a3?w=400&q=80",
        date: "2026-06-30",
      },
      {
        title: "Kenyan artist Wangechi Mutu opens new permanent commission at the Met",
        category: "Exhibitions",
        href: "/magazine/exhibitions-fairs/wangechi-mutu-met",
        imageUrl: "https://images.unsplash.com/photo-1531913764164-f85c52e6e654?w=400&q=80",
        date: "2026-06-28",
      },
      {
        title: "Ghana's art market sees record growth in the secondary market",
        category: "Art Market",
        href: "/magazine/art-news/ghana-market-growth",
        imageUrl: "https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=400&q=80",
        date: "2026-06-25",
      },
      {
        title: "1-54 London 2026: What to expect from this year's premier African art fair",
        category: "Exhibitions & Fairs",
        href: "/magazine/exhibitions-fairs/1-54-london-2026",
        imageUrl: "https://images.unsplash.com/photo-1518998053901-5348d3961a04?w=400&q=80",
        date: "2026-06-22",
      },
    ],
    text: [
      {
        title: "Nigeria's National Museum announces landmark repatriation agreement with British institutions",
        category: "Art News",
        href: "/magazine/art-news/nigeria-repatriation",
        date: "2026-06-20",
        author: "Chisom Eze",
      },
      {
        title: "Decolonising the art archive: How Nigerian institutions are reclaiming their histories",
        category: "Academia",
        href: "/magazine/academia/decolonising-archive",
        date: "2026-06-18",
        author: "Tunde Adeyemi",
      },
      {
        title: "In conversation with El Anatsui: Material, memory, and monumentality",
        category: "Interviews",
        href: "/magazine/interviews/el-anatsui",
        date: "2026-06-15",
        author: "Nkechi Obi",
      },
      {
        title: "Collecting Now: Five emerging African artists to watch in the second half of 2026",
        category: "Collecting Now",
        href: "/magazine/collecting-now/five-emerging-artists",
        date: "2026-06-12",
        author: "Yemi Hassan",
      },
    ],
  },
  {
    title: "Art Market",
    slug: "art-news",
    subCategories: [],
    hero: {
      title: "19th-century bronze: Laceeba leads Lceeba Old Master auctions, selling for £1.5m at Sotheby's",
      excerpt: "A spectacular result for the historic bronze underscores growing institutional appetite for pre-colonial African objects.",
      category: "Art Market",
      href: "/magazine/art-news/laceeba-bronze-sothebys",
      imageUrl: "https://images.unsplash.com/photo-1554907984-15263bfd63bd?w=900&q=80",
      date: "2026-06-10",
      author: "Samuel Agwu",
    },
    small: [
      {
        title: "Christie's September auction to feature rare Yoruba beaded crown",
        category: "Art Market",
        href: "/magazine/art-news/christies-yoruba-crown",
        imageUrl: "https://images.unsplash.com/photo-1560343090-f0409e92791a?w=400&q=80",
        date: "2026-06-08",
      },
      {
        title: "The market for South African modernists is finally catching up",
        category: "Art Market",
        href: "/magazine/art-news/south-african-modernists",
        imageUrl: "https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=400&q=80",
        date: "2026-06-05",
      },
      {
        title: "Gallery Friday: inside the fastest-growing art fair in East Africa",
        category: "Exhibitions",
        href: "/magazine/exhibitions-fairs/gallery-friday",
        imageUrl: "https://images.unsplash.com/photo-1536924940846-227afb31e2a5?w=400&q=80",
        date: "2026-06-02",
      },
      {
        title: "How digital platforms are disrupting the traditional African art market",
        category: "Art Market",
        href: "/magazine/collecting-now/digital-disruption",
        imageUrl: "https://images.unsplash.com/photo-1519389950473-47ba0277781c?w=400&q=80",
        date: "2026-05-30",
      },
    ],
    text: [
      {
        title: "Prices for Enwonwu works have tripled in five years. What's driving the surge?",
        category: "Art Market",
        href: "/magazine/art-news/enwonwu-price-surge",
        date: "2026-05-28",
        author: "Bisi Afolabi",
      },
      {
        title: "Understanding provenance: why collectors must ask harder questions",
        category: "Academia",
        href: "/magazine/academia/understanding-provenance",
        date: "2026-05-25",
        author: "Dr. Amara Diallo",
      },
      {
        title: "Inside a Nairobi collector's extraordinary trove of East African ceramics",
        category: "Collecting Now",
        href: "/magazine/collecting-now/nairobi-ceramics",
        date: "2026-05-22",
        author: "Wanjiku Kamau",
      },
      {
        title: "Auction preview: ten lots every African art collector should watch this season",
        category: "Art Market",
        href: "/magazine/art-news/ten-lots-to-watch",
        date: "2026-05-20",
        author: "Samuel Agwu",
      },
    ],
  },
];

// Map Sanity articles to our sections if they exist, otherwise use fallbacks
let sections: any[] = [];

if (sanityArticles && sanityArticles.length > 0) {
  // 1. "Latest" section (always at top, fixed maximum of 9 articles across all categories)
  const latestHero = sanityArticles[0];
  const latestSmall = sanityArticles.slice(1, 5);
  const latestText = sanityArticles.slice(5, 9);

  if (latestHero) {
    sections.push({
      title: "Latest",
      slug: latestHero.primaryCategory?.slug?.current || "art-news",
      subCategories: [],
      hero: {
        title: latestHero.title,
        excerpt: latestHero.excerpt,
        category: latestHero.primaryCategory?.name || "Latest",
        href: `/magazine/${latestHero.primaryCategory?.slug?.current || "art-news"}/${latestHero.slug?.current}`,
        imageUrl: latestHero.featuredImage ? urlFor(latestHero.featuredImage).width(900).url() : undefined,
        date: latestHero.publishedAt,
        author: latestHero.author?.name || "Ncheta Team"
      },
      small: latestSmall.map((art: any) => ({
        title: art.title,
        category: art.primaryCategory?.name || "Latest",
        href: `/magazine/${art.primaryCategory?.slug?.current || "art-news"}/${art.slug?.current}`,
        imageUrl: art.featuredImage ? urlFor(art.featuredImage).width(400).url() : undefined,
        date: art.publishedAt
      })),
      text: latestText.map((art: any) => ({
        title: art.title,
        category: art.primaryCategory?.name || "Latest",
        href: `/magazine/${art.primaryCategory?.slug?.current || "art-news"}/${art.slug?.current}`,
        date: art.publishedAt,
        author: art.author?.name || "Ncheta Team"
      }))
    });
  }

  // 2. Category sections below Latest (capped by MAX_HOMEPAGE_CATEGORIES)
  if (sanityCategories && sanityCategories.length > 0) {
    const topCategories = sanityCategories.filter((cat: any) => !cat.parentCategory);
    const activeCategories = topCategories.slice(0, MAX_HOMEPAGE_CATEGORIES);

    for (const category of activeCategories) {
      const subCats = sanityCategories.filter(
        (c: any) => c.parentCategory && (c.parentCategory._id === category._id || c.parentCategory.slug?.current === category.slug?.current)
      );

      const categoryArticles = sanityArticles.filter((art: any) => {
        const artCatSlug = art.primaryCategory?.slug?.current;
        const artParentSlug = art.primaryCategory?.parentCategory?.slug?.current;
        return artCatSlug === category.slug?.current || artParentSlug === category.slug?.current;
      });

      if (categoryArticles.length === 0) continue;

      const featuredArticles: any[] = category.featuredArticles || [];
      const featuredIds = new Set(featuredArticles.map((a: any) => a._id));
      const unfeaturedArticles = categoryArticles.filter((a: any) => !featuredIds.has(a._id));

      const combinedArticles = [...featuredArticles, ...unfeaturedArticles].slice(0, MAX_ARTICLES_PER_CATEGORY);

      const hero = combinedArticles[0];
      const small = combinedArticles.slice(1, 5);
      const text = combinedArticles.slice(5, MAX_ARTICLES_PER_CATEGORY);

      sections.push({
        title: category.name,
        slug: category.slug?.current || "art-news",
        subCategories: subCats.map((s: any) => ({ name: s.name, slug: s.slug?.current })),
        hero: hero ? {
          title: hero.title,
          excerpt: hero.excerpt,
          category: hero.primaryCategory?.name || category.name,
          href: `/magazine/${hero.primaryCategory?.slug?.current || category.slug?.current || "art-news"}/${hero.slug?.current}`,
          imageUrl: hero.featuredImage ? urlFor(hero.featuredImage).width(900).url() : undefined,
          date: hero.publishedAt,
          author: hero.author?.name || "Ncheta Team"
        } : null,
        small: small.map((art: any) => ({
          title: art.title,
          category: art.primaryCategory?.name || category.name,
          href: `/magazine/${art.primaryCategory?.slug?.current || category.slug?.current || "art-news"}/${art.slug?.current}`,
          imageUrl: art.featuredImage ? urlFor(art.featuredImage).width(400).url() : undefined,
          date: art.publishedAt
        })),
        text: text.map((art: any) => ({
          title: art.title,
          category: art.primaryCategory?.name || category.name,
          href: `/magazine/${art.primaryCategory?.slug?.current || category.slug?.current || "art-news"}/${art.slug?.current}`,
          date: art.publishedAt,
          author: art.author?.name || "Ncheta Team"
        }))
      });
    }
  }
}

if (sections.length === 0) {
  sections = fallbackSections;
}
---

<Layout
  title="Home"
  description="Ncheta Magazine — African art news, academia, interviews, and exhibitions."
>
  <Header />

  <main>
    {sections.map((section, sectionIndex) => (
      <>
        {sectionIndex > 0 && (
          <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <hr class="border-t border-noir/15 mt-8" />
            <hr class="border-t border-noir/15 mt-8" />
          </div>
        )}
        <section
          class:list={[
            "max-w-7xl mx-auto px-4 sm:px-6 lg:px-8",
            sectionIndex === 0 ? "pt-8 pb-10" : "pt-6 pb-10",
          ]}
        >
          <!-- Section header with Subcategory chips -->
          <div class="flex flex-col sm:flex-row sm:items-baseline justify-between mb-8 gap-3">
            <div class="flex items-center gap-3 flex-wrap">
              <h2 class="font-cinzel font-bold text-2xl md:text-3xl text-noir">
                {section.title}
              </h2>
              {section.subCategories && section.subCategories.length > 0 && (
                <div class="flex items-center gap-1.5 flex-wrap">
                  {section.subCategories.map((sub: any) => (
                    <a
                      href={`/magazine/${sub.slug}`}
                      class="px-2.5 py-0.5 font-inter text-[11px] font-medium bg-noir/5 hover:bg-noir/10 text-noir/70 hover:text-noir rounded-full transition-colors"
                    >
                      {sub.name}
                    </a>
                  ))}
                </div>
              )}
            </div>
            <a
              href={`/magazine/${section.slug}`}
              class="font-inter text-xs font-medium text-maroon transition-colors duration-150 uppercase tracking-widest shrink-0"
            >
              Read all →
            </a>
          </div>

          <!-- Hero + 2×2 grid of small cards -->
          <div class="grid grid-cols-1 lg:grid-cols-[1fr_1fr] xl:grid-cols-[3fr_2fr] gap-6 mb-0">
            <!-- Hero card -->
            <div>
              {section.hero && (
                <ArticleCard
                  variant="hero"
                  title={section.hero.title}
                  excerpt={section.hero.excerpt}
                  category={section.hero.category}
                  href={section.hero.href}
                  imageUrl={section.hero.imageUrl}
                  author={section.hero.author}
                  date={section.hero.date}
                />
              )}
            </div>

            <!-- Small cards grid -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-4 lg:mt-0">
              {section.small.map((card: any) => (
                <ArticleCard
                  variant="small"
                  title={card.title}
                  category={card.category}
                  href={card.href}
                  imageUrl={card.imageUrl}
                  date={card.date}
                />
              ))}
            </div>
          </div>

          <!-- Text-only article links below -->
          {section.text && section.text.length > 0 && (
            <div class="border-t border-noir/10 mt-12 pt-1 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-x-8">
              {section.text.map((card: any) => (
                <ArticleCard
                  variant="text"
                  title={card.title}
                  category={card.category}
                  href={card.href}
                  date={card.date}
                  author={card.author}
                  bordered
                />
              ))}
            </div>
          )}
        </section>
      </>
    ))}

    <!-- Mid-page newsletter CTA strip -->
    <section class="bg-noir py-16 my-4">
      <div class="max-w-2xl mx-auto px-4 sm:px-6 text-center">
        <h2 class="font-cinzel font-bold text-2xl md:text-3xl text-cotton mb-3">
          Subscribe to the Ncheta Newsletter
        </h2>
        <p class="font-inter text-sm text-cotton/80 mb-8 max-w-md mx-auto leading-relaxed">
          Weekly curation of the most important African art stories — delivered straight to your inbox.
        </p>
        <form
          id="home-newsletter-form"
          class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto"
          novalidate
        >
          <input
            id="home-email"
            name="email"
            type="email"
            required
            placeholder="Enter your email address"
            aria-label="Your email address"
            class="flex-1 px-4 py-3 bg-cotton/10 border border-cotton/20 text-cotton placeholder:text-cotton/35 font-inter text-sm focus:outline-none focus:border-lime focus:ring-1 focus:ring-lime/40 transition-all"
          />
          <button
            type="submit"
            class="px-6 py-3 bg-lime text-noir font-inter font-medium text-sm hover:bg-lime/90 transition-colors duration-150 whitespace-nowrap"
          >
            Subscribe
          </button>
        </form>
        <p id="home-newsletter-status" role="status" aria-live="polite" class="mt-3 font-inter text-sm text-cotton/50 hidden"></p>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  (() => {
    const form   = document.getElementById("home-newsletter-form") as HTMLFormElement | null;
    const status = document.getElementById("home-newsletter-status") as HTMLParagraphElement | null;
    if (!form || !status) return;

    form.addEventListener("submit", async (e: Event) => {
      e.preventDefault();
      const input = form.elements.namedItem("email") as HTMLInputElement;
      const email = input?.value.trim();
      if (!email) return;

      const btn = form.querySelector("button") as HTMLButtonElement;
      btn.disabled = true;
      btn.textContent = "Subscribing…";

      try {
        const res = await fetch("/api/newsletter", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ email }),
        });
        if (res.ok) {
          (window as any).umami?.track?.("Newsletter Signup");
          form.innerHTML = `<p class="font-inter text-sm text-lime">✓ You're subscribed! Check your inbox.</p>`;
        } else { throw new Error(); }
      } catch {
        btn.disabled = false;
        btn.textContent = "Subscribe";
        status.textContent = "Something went wrong. Please try again.";
        status.className = "mt-3 font-inter text-sm text-maroon/80 block";
      }
    });
  })();
</script>
