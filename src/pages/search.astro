---
// Search page — Pagefind shell
import Layout from "../layouts/Layout.astro";
import Header from "../components/navigation/Header.astro";
import Footer from "../components/navigation/Footer.astro";
---

<Layout title="Search" description="Search Ncheta Magazine articles and resources.">
  <Header />
  <main class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16 min-h-[60vh]">
    <h1 class="font-cinzel font-bold text-3xl md:text-4xl text-noir mb-8">Search</h1>
    <div id="search"></div>
  </main>
  <Footer />
</Layout>

<script is:inline>
  // Pagefind UI loads from post-build output
  const s = document.createElement("script");
  s.src = "/pagefind/pagefind-ui.js";
  s.onload = () => { new PagefindUI({ element: "#search" }); };
  document.head.appendChild(s);
</script>
<link rel="stylesheet" href="/pagefind/pagefind-ui.css" />