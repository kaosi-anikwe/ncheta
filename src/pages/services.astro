---
// Services page — Cotton background, brand-correct forms and cards
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/navigation/Footer.astro";

const services = [
  {
    title: "Artist Documentation",
    description: "Professional archival documentation of artworks, exhibitions, and studio practice. High-resolution imaging, cataloguing, and digital portfolio creation for galleries, estates, and independent artists.",
    icon: "◉",
    slug: "artist-documentation",
  },
  {
    title: "Critical Essays",
    description: "Scholarly essays and exhibition texts written by experienced art writers with deep knowledge of African art history. Rigorous research, contextual analysis, and publication-ready prose for galleries and institutions.",
    icon: "◈",
    slug: "critical-essays",
  },
  {
    title: "Research Reports",
    description: "In-depth market analysis and art historical research commissioned for galleries, collectors, foundations, and cultural institutions. Delivered as structured reports suitable for publication or internal use.",
    icon: "◇",
    slug: "research-reports",
  },
];
---

<Layout
  title="Services"
  description="Professional art documentation, critical essays, and research services from Ncheta Magazine."
>
  <Header />
  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">

    <!-- Breadcrumb -->
    <nav class="mb-10 font-inter text-xs text-noir/40 flex gap-2" aria-label="Breadcrumb">
      <a href="/" class=" transition-colors">Home</a>
      <span>/</span>
      <span class="text-noir/60">Services</span>
    </nav>

    <!-- Page header -->
    <div class="mb-14 border-b border-noir/10 pb-10">
      <h1 class="font-cinzel font-bold text-4xl md:text-5xl text-noir mb-4">Our Services</h1>
      <p class="font-inter text-base text-noir/55 max-w-2xl leading-relaxed">
        Professional services for artists, galleries, collectors, and institutions — delivered with scholarly rigour and deep cultural sensitivity.
      </p>
    </div>

    <!-- Service cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-noir/10 mb-20 border border-noir/10">
      {services.map((service) => (
        <div class="bg-cotton p-8 md:p-10 hover:bg-noir/3 transition-colors duration-200 group">
          <span class="font-cinzel text-3xl text-noir/25 group- transition-colors duration-200 block mb-5">
            {service.icon}
          </span>
          <h2 class="font-cinzel font-bold text-xl text-noir mb-3">{service.title}</h2>
          <p class="font-inter text-sm text-noir/55 leading-relaxed">{service.description}</p>
        </div>
      ))}
    </div>

    <!-- Inquiry form -->
    <div class="max-w-2xl mx-auto">
      <div class="mb-10 border-b border-noir/10 pb-8">
        <h2 class="font-cinzel font-bold text-2xl md:text-3xl text-noir mb-2">Make an Enquiry</h2>
        <p class="font-inter text-sm text-noir/50">Tell us about your project — we'll respond within 48 hours.</p>
      </div>

      <form id="service-form" class="space-y-5" novalidate aria-label="Service enquiry form">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div class="space-y-1.5">
            <label for="firstName" class="block font-inter text-xs font-medium text-noir/55 uppercase tracking-wider">
              First Name <span class="text-cherry" aria-hidden="true">*</span>
            </label>
            <input
              id="firstName" name="firstName" type="text" required
              placeholder="First name" aria-required="true"
              class="w-full px-4 py-3 bg-cotton border border-noir/20 font-inter text-sm text-noir placeholder:text-noir/30 focus:outline-none focus:border-lime focus:ring-2 focus:ring-lime/30 transition-all"
            />
          </div>
          <div class="space-y-1.5">
            <label for="lastName" class="block font-inter text-xs font-medium text-noir/55 uppercase tracking-wider">
              Last Name <span class="text-cherry" aria-hidden="true">*</span>
            </label>
            <input
              id="lastName" name="lastName" type="text" required
              placeholder="Last name" aria-required="true"
              class="w-full px-4 py-3 bg-cotton border border-noir/20 font-inter text-sm text-noir placeholder:text-noir/30 focus:outline-none focus:border-lime focus:ring-2 focus:ring-lime/30 transition-all"
            />
          </div>
        </div>

        <div class="space-y-1.5">
          <label for="email" class="block font-inter text-xs font-medium text-noir/55 uppercase tracking-wider">
            Email <span class="text-cherry" aria-hidden="true">*</span>
          </label>
          <input
            id="email" name="email" type="email" required
            placeholder="your@email.com" aria-required="true"
            class="w-full px-4 py-3 bg-cotton border border-noir/20 font-inter text-sm text-noir placeholder:text-noir/30 focus:outline-none focus:border-lime focus:ring-2 focus:ring-lime/30 transition-all"
          />
        </div>

        <div class="space-y-1.5">
          <label for="serviceType" class="block font-inter text-xs font-medium text-noir/55 uppercase tracking-wider">
            Service Type <span class="text-cherry" aria-hidden="true">*</span>
          </label>
          <select
            id="serviceType" name="serviceType" required aria-required="true"
            class="w-full px-4 py-3 bg-cotton border border-noir/20 font-inter text-sm text-noir focus:outline-none focus:border-lime focus:ring-2 focus:ring-lime/30 transition-all appearance-none cursor-pointer"
          >
            <option value="">Select a service…</option>
            {services.map((s) => (
              <option value={s.slug}>{s.title}</option>
            ))}
          </select>
        </div>

        <div class="space-y-1.5">
          <label for="message" class="block font-inter text-xs font-medium text-noir/55 uppercase tracking-wider">
            Project Details <span class="text-cherry" aria-hidden="true">*</span>
          </label>
          <textarea
            id="message" name="message" required rows={5}
            placeholder="Describe your project, timeline, and any specific requirements…" aria-required="true"
            class="w-full px-4 py-3 bg-cotton border border-noir/20 font-inter text-sm text-noir placeholder:text-noir/30 focus:outline-none focus:border-lime focus:ring-2 focus:ring-lime/30 transition-all resize-y min-h-30"
          ></textarea>
        </div>

        <!-- Noir/Cotton submit → Lime hover -->
        <button
          type="submit"
          class="w-full px-6 py-3 bg-noir text-cotton font-inter font-medium text-sm border border-noir hover:bg-lime hover:text-noir hover:border-lime focus:outline-none focus:ring-2 focus:ring-lime/50 focus:ring-offset-2 focus:ring-offset-cotton transition-all duration-200 disabled:opacity-60"
        >
          Submit Enquiry
        </button>

        <p id="service-status" role="status" aria-live="polite" class="font-inter text-sm hidden"></p>
      </form>

      <!-- Success state -->
      <div id="form-success" class="hidden text-center py-12">
        <p class="font-cinzel font-bold text-2xl text-noir mb-2">Enquiry Received</p>
        <p class="font-inter text-sm text-noir/55">We'll get back to you within 48 hours.</p>
      </div>
    </div>

  </main>
  <Footer />
</Layout>

<script>
  (() => {
    const form    = document.getElementById("service-form")   as HTMLFormElement | null;
    const success = document.getElementById("form-success")   as HTMLElement | null;
    const status  = document.getElementById("service-status") as HTMLParagraphElement | null;
    if (!form) return;

    form.addEventListener("submit", async (e: Event) => {
      e.preventDefault();
      const data = Object.fromEntries(new FormData(form).entries());
      const btn  = form.querySelector("button[type=submit]") as HTMLButtonElement;
      btn.disabled = true;
      btn.textContent = "Sending…";

      try {
        await fetch("/api/inbound", {
          method:  "POST",
          headers: { "Content-Type": "application/json" },
          body:    JSON.stringify(data),
        });
        (window as any).umami?.track?.("B2B Service Inquiry", { type: data.serviceType });
        form.classList.add("hidden");
        success?.classList.remove("hidden");
      } catch {
        btn.disabled = false;
        btn.textContent = "Submit Enquiry";
        if (status) {
          status.textContent = "Something went wrong. Please try again.";
          status.className = "font-inter text-sm text-cherry block";
        }
      }
    });
  })();
</script>