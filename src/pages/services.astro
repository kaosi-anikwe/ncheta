---
// Services page — Cotton background, brand-correct forms and cards
import Layout from "../layouts/Layout.astro";
import Header from "../components/navigation/Header.astro";
import Footer from "../components/navigation/Footer.astro";

export const services = [
  {
    title: "Features and Artist Profiles",
    description: "Long-form features, first-person essays and interviews.",
    icon: "◉",
    slug: "features_and_artist_profiles",
  },
  {
    title: "Institutional and Gallery Coverage",
    description:
      "Exhibitions, fairs and shows, acquisitions, programmes, and retrospective pieces.",
    icon: "◈",
    slug: "institutional_and_gallery_coverage",
  },
  {
    title: "Documentation and Archive Support",
    description:
      "We work directly with galleries, estates, and institutions on cataloguing, research, and archive building.",
    icon: "◇",
    slug: "documentation_and_archive_support",
  },
  {
    title: "Advertising Placements",
    description:
      "In-magazine placements for galleries, fairs, auction houses, and institutions.",
    icon: "◉",
    slug: "advertising_placements",
  },
  {
    title: "Newsletter Advert Placement",
    description:
      "Advert spots in the Ncheta Weekly newsletter, sent straight to readers who open it to see what's happening in the art ecosystem.",
    icon: "◈",
    slug: "newsletter_advert_placement",
  },
  {
    title: "Partnership and Custom Features",
    description:
      "We build sponsored content around your brand, institution or programme: labelled clearly as sponsored.",
    icon: "◇",
    slug: "partnership_and_custom_features",
  },
];

export const contactServices = [
  {
    title: "General Enquiry",
    description:
      "If your project doesn't fit into the above categories, please reach out and we'll discuss how we can help.",
    icon: "◌",
    slug: "general_enquiry",
  },
  ...services,
];
---

<Layout
  title="Services"
  description="Professional art documentation, critical essays, and research services from Ncheta Magazine."
>
  <Header />
  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <!-- Breadcrumb -->
    <nav
      class="mb-10 font-inter text-xs text-noir/40 flex gap-2"
      aria-label="Breadcrumb"
    >
      <a href="/" class="transition-colors">Home</a>
      <span>/</span>
      <span class="text-noir/60">Services</span>
    </nav>

    <!-- Page header -->
    <div class="mb-14 border-b border-noir/10 pb-10">
      <h1 class="font-cinzel font-bold text-4xl md:text-5xl text-noir mb-4">
        Our Services
      </h1>
      <p class="font-inter text-base text-noir/55 max-w-2xl leading-relaxed">
        Ncheta magazine works with artists, galleries, brands and institutions
        affiliated with West African art to provide media coverage.
        <br />Here’s what we offer:
      </p>
    </div>

    <!-- Service cards -->
    <div
      class="grid grid-cols-1 md:grid-cols-3 gap-px bg-noir/10 mb-20 border border-noir/10"
    >
      {
        services.map((service) => (
          <div class="bg-cotton p-8 md:p-10 hover:bg-noir/3 transition-colors duration-200 group">
            <span class="font-cinzel text-3xl text-noir/25 group- transition-colors duration-200 block mb-5">
              {service.icon}
            </span>
            <h2 class="font-cinzel font-bold text-xl text-noir mb-3">
              {service.title}
            </h2>
            <p class="font-inter text-sm text-noir/55 leading-relaxed">
              {service.description}
            </p>
          </div>
        ))
      }
    </div>

    <!-- Inquiry form -->
    <div class="max-w-2xl mx-auto">
      <div class="mb-10 border-b border-noir/10 pb-8">
        <h2 class="font-cinzel font-bold text-2xl md:text-3xl text-noir mb-2">
          Make an Enquiry
        </h2>
        <p class="font-inter text-sm text-noir/50">
          Tell us about your project — we'll respond within 48 hours.
        </p>
      </div>

      <form
        id="service-form"
        class="space-y-5"
        novalidate
        aria-label="Service enquiry form"
      >
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div class="space-y-1.5">
            <label
              for="firstName"
              class="block font-inter text-xs font-medium text-noir/55 uppercase tracking-wider"
            >
              First Name <span class="text-maroon" aria-hidden="true">*</span>
            </label>
            <input
              id="firstName"
              name="firstName"
              type="text"
              required
              placeholder="First name"
              aria-required="true"
              class="w-full px-4 py-3 bg-cotton border border-noir/20 font-inter text-sm text-noir placeholder:text-noir/30 focus:outline-none focus:border-maroon focus:ring-2 focus:ring-maroon/30 transition-all"
            />
          </div>
          <div class="space-y-1.5">
            <label
              for="lastName"
              class="block font-inter text-xs font-medium text-noir/55 uppercase tracking-wider"
            >
              Last Name <span class="text-maroon" aria-hidden="true">*</span>
            </label>
            <input
              id="lastName"
              name="lastName"
              type="text"
              required
              placeholder="Last name"
              aria-required="true"
              class="w-full px-4 py-3 bg-cotton border border-noir/20 font-inter text-sm text-noir placeholder:text-noir/30 focus:outline-none focus:border-maroon focus:ring-2 focus:ring-maroon/30 transition-all"
            />
          </div>
        </div>

        <div class="space-y-1.5">
          <label
            for="email"
            class="block font-inter text-xs font-medium text-noir/55 uppercase tracking-wider"
          >
            Email <span class="text-maroon" aria-hidden="true">*</span>
          </label>
          <input
            id="email"
            name="email"
            type="email"
            required
            placeholder="your@email.com"
            aria-required="true"
            class="w-full px-4 py-3 bg-cotton border border-noir/20 font-inter text-sm text-noir placeholder:text-noir/30 focus:outline-none focus:border-maroon focus:ring-2 focus:ring-maroon/30 transition-all"
          />
        </div>

        <div class="space-y-1.5">
          <label
            for="serviceType"
            class="block font-inter text-xs font-medium text-noir/55 uppercase tracking-wider"
          >
            Service Type <span class="text-maroon" aria-hidden="true">*</span>
          </label>
          <select
            id="serviceType"
            name="serviceType"
            required
            aria-required="true"
            class="w-full px-4 py-3 bg-cotton border border-noir/20 font-inter text-sm text-noir focus:outline-none focus:border-maroon focus:ring-2 focus:ring-maroon/30 transition-all appearance-none cursor-pointer"
          >
            <option value="">Select a service…</option>
            {
              contactServices.map((s) => (
                <option value={s.slug}>{s.title}</option>
              ))
            }
          </select>
        </div>

        <div class="space-y-1.5">
          <label
            for="message"
            class="block font-inter text-xs font-medium text-noir/55 uppercase tracking-wider"
          >
            Project Details <span class="text-maroon" aria-hidden="true">*</span
            >
          </label>
          <textarea
            id="message"
            name="message"
            required
            rows={5}
            placeholder="Describe your project, timeline, and any specific requirements…"
            aria-required="true"
            class="w-full px-4 py-3 bg-cotton border border-noir/20 font-inter text-sm text-noir placeholder:text-noir/30 focus:outline-none focus:border-maroon focus:ring-2 focus:ring-maroon/30 transition-all resize-y min-h-30"
          ></textarea>
        </div>

        <p class="font-inter text-xs text-noir/45 leading-relaxed">
          By submitting this form, you also agree to subscribe to our weekly
          newsletter. You can unsubscribe at any time.
        </p>

        <!-- Noir/Cotton submit → Lime hover -->
        <button
          type="submit"
          class="w-full px-6 py-3 bg-noir text-cotton font-inter font-medium text-sm border border-noir hover:bg-lime hover:text-noir hover:border-lime focus:outline-none focus:ring-2 focus:ring-lime/50 focus:ring-offset-2 focus:ring-offset-cotton transition-all duration-200 disabled:opacity-60 cursor-pointer"
        >
          Submit Enquiry
        </button>

        <p
          id="service-status"
          role="status"
          aria-live="polite"
          class="font-inter text-sm hidden"
        >
        </p>
      </form>

      <!-- Success state -->
      <div id="form-success" class="hidden text-center py-12">
        <p class="font-cinzel font-bold text-2xl text-noir mb-2">
          Enquiry Received
        </p>
        <p class="font-inter text-sm text-noir/55">
          We'll get back to you within 48 hours.
        </p>
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  (() => {
    const form = document.getElementById(
      "service-form",
    ) as HTMLFormElement | null;
    const success = document.getElementById(
      "form-success",
    ) as HTMLElement | null;
    const status = document.getElementById(
      "service-status",
    ) as HTMLParagraphElement | null;
    if (!form) return;

    form.addEventListener("submit", async (e: Event) => {
      e.preventDefault();
      const data = Object.fromEntries(new FormData(form).entries());
      const btn = form.querySelector(
        "button[type=submit]",
      ) as HTMLButtonElement;
      btn.disabled = true;
      btn.textContent = "Sending…";

      try {
        await fetch("/api/inbound", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(data),
        });
        (window as any).umami?.track?.("B2B Service Inquiry", {
          type: data.serviceType,
        });
        form.classList.add("hidden");
        success?.classList.remove("hidden");
      } catch {
        btn.disabled = false;
        btn.textContent = "Submit Enquiry";
        if (status) {
          status.textContent = "Something went wrong. Please try again.";
          status.className = "font-inter text-sm text-maroon block";
        }
      }
    });
  })();
</script>
