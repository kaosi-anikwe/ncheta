          <path d="M269.13,144.3h-1.45l-1-2.79H261.2l-1,2.79h-1.45l4.3-11.42h1.82Zm-3-4-2.22-6-2.23,6Z"/>
          <path d="M274.57,132.88h8.06v1.55L276,143h6.61v1.26h-8.08v-1.63l6.6-8.53h-6.58Z"/>
          <path d="M288.82,132.88h1.35V144.3h-1.35Z"/>
          <path d="M298.11,134.79v9.51h-1.35V132.88h1.72l6.48,9.64v-9.64h1.36V144.3h-1.76Z"/>
          <path d="M314.25,134.08v3.83h5v1.22h-5v4h6.16v1.22H312.9V132.88h7.51v1.2Z"/>
        </svg>
      </a>

      <!-- Right controls -->
      <div class="flex items-center gap-2 md:gap-3">

        <!-- Inline search input (hidden on mobile) -->
        <div class="relative hidden sm:flex items-center">
          <input
            id="nav-search"
            type="search"
            placeholder="Search articles..."
            class="w-44 md:w-56 h-8 pl-3 pr-8 text-xs font-inter bg-noir/5 border border-noir/15 rounded-sm text-noir placeholder:text-noir/40 focus:outline-none focus:border-noir/30 focus:bg-white transition-colors"
            aria-label="Search articles"
          />
          <button
            type="button"
            id="nav-search-btn"
            class="absolute right-2 text-noir/40 hover:text-noir transition-colors"
            aria-label="Submit search"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
          </button>
        </div>

        <!-- Subscribe button -->
        <button
          id="subscribe-btn"
          type="button"
          class="h-8 px-4 text-xs font-inter font-medium border border-noir/30 text-noir hover:bg-noir hover:text-cotton transition-colors rounded-sm focus:outline-none focus-visible:ring-2 focus-visible:ring-lime/60 whitespace-nowrap"
        >
          Subscribe
        </button>

        <!-- Mobile search icon -->
        <button
          type="button"
          id="mobile-search-btn"
          class="sm:hidden p-1.5 text-noir/60 hover:text-noir transition-colors"
          aria-label="Search"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </button>

        <!-- Mobile menu toggle -->
        <details class="lg:hidden group relative">
          <summary class="list-none cursor-pointer p-1.5 text-noir/60 hover:text-noir transition-colors" aria-label="Toggle menu">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 group-open:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 hidden group-open:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </summary>
          <nav class="absolute top-full right-0 w-72 bg-cotton border border-noir/10 shadow-xl z-50" aria-label="Mobile navigation">
            <div class="py-2">
              {navItems.map((item) => {
                const active = isActive(item.href);
                return (
                  <a
                    href={item.href}
                    aria-current={active ? "page" : undefined}
                    class:list={[
                      "flex items-center px-5 py-3 font-inter text-sm font-medium transition-colors duration-150 border-l-2",
                      active ? "text-noir border-lime bg-lime/10" : "text-noir/65 hover:text-noir hover:bg-noir/5 border-transparent",
                    ]}
                  >
                    {item.label}
                  </a>
                );
              })}
            </div>
          </nav>
        </details>

      </div>
    </div>
  </div>

  <!-- Row 2: Nav links (desktop only) -->
  <div class="hidden lg:block border-t border-noir/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="flex items-center justify-around" aria-label="Primary navigation">
        {navItems.map((item) => {
          const active = isActive(item.href);
          return (
            <a
              href={item.href}
              aria-current={active ? "page" : undefined}
              class:list={[
                "relative px-3 py-2.5 font-inter text-[13px] font-medium tracking-wide transition-colors whitespace-nowrap focus:outline-none focus-visible:ring-2 focus-visible:ring-lime/60 rounded-sm nav-item",
                active ? "text-noir nav-item--active" : "text-noir/60 hover:text-noir",
              ]}
            >
              {item.label}
            </a>
          );
        })}
      </nav>
    </div>
  </div>

</header>

<!-- Subscribe modal -->
<div
  id="subscribe-modal"
  class="fixed inset-0 z-100 hidden items-center justify-center p-4"
  role="dialog"
  aria-modal="true"
  aria-labelledby="modal-title"
>
  <div id="modal-backdrop" class="absolute inset-0 bg-noir/50"></div>
  <div class="relative bg-cotton border border-noir/15 shadow-2xl w-full max-w-md p-8 md:p-10">
    <button
      id="modal-close"
      type="button"
      class="absolute top-4 right-4 p-1 text-noir/40 hover:text-noir transition-colors"
      aria-label="Close"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
    <h2 id="modal-title" class="font-cinzel font-bold text-2xl text-noir mb-2">Stay Informed</h2>
    <p class="font-inter text-sm text-noir/60 mb-6 leading-relaxed">
      Weekly curation of the most important stories in African art — delivered to your inbox.
    </p>
    <form id="modal-form" class="space-y-3" novalidate>
      <input
        id="modal-email"
        name="email"
        type="email"
        required
        placeholder="your@email.com"
        class="w-full h-10 px-4 text-sm font-inter bg-white border border-noir/20 text-noir placeholder:text-noir/35 focus:outline-none focus:border-noir/50 transition-colors rounded-sm"
      />
      <button
        type="submit"
        class="w-full h-10 bg-noir text-cotton font-inter text-sm font-medium hover:bg-cherry transition-colors rounded-sm focus:outline-none focus-visible:ring-2 focus-visible:ring-lime/60"
      >
        Subscribe
      </button>
    </form>
    <div id="modal-success" class="hidden text-center py-4">
      <p class="font-cinzel font-bold text-noir text-lg">You're in.</p>
      <p class="font-inter text-sm text-noir/60 mt-1">Check your inbox for a confirmation email.</p>
    </div>
  </div>
</div>

<script>
  // Search
  const searchInput = document.getElementById("nav-search") as HTMLInputElement | null;
  document.getElementById("nav-search-btn")?.addEventListener("click", () => {
    const q = searchInput?.value.trim();
    if (q) window.location.href = `/resources/search?q=${encodeURIComponent(q)}`;
  });
  searchInput?.addEventListener("keydown", (e: KeyboardEvent) => {
    if (e.key === "Enter") {
      const q = (e.target as HTMLInputElement).value.trim();
      if (q) window.location.href = `/resources/search?q=${encodeURIComponent(q)}`;
    }
  });
  document.getElementById("mobile-search-btn")?.addEventListener("click", () => {
    window.location.href = "/resources/search";
  });

  // Subscribe modal
  const modal = document.getElementById("subscribe-modal") as HTMLElement;
  const openModal = () => {
    modal.classList.remove("hidden");
    modal.classList.add("flex");
    document.body.style.overflow = "hidden";
    (document.getElementById("modal-email") as HTMLInputElement | null)?.focus();
  };
  const closeModal = () => {
    modal.classList.add("hidden");
    modal.classList.remove("flex");
    document.body.style.overflow = "";
  };
  document.getElementById("subscribe-btn")?.addEventListener("click", openModal);
  document.getElementById("modal-close")?.addEventListener("click", closeModal);
  document.getElementById("modal-backdrop")?.addEventListener("click", closeModal);
  document.addEventListener("keydown", (e: KeyboardEvent) => { if (e.key === "Escape") closeModal(); });

  document.getElementById("modal-form")?.addEventListener("submit", async (e: SubmitEvent) => {
    e.preventDefault();
    const email = (document.getElementById("modal-email") as HTMLInputElement).value;
    try {
      await fetch("/api/newsletter", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ email }),
      });
      (window as any).umami?.track?.("Newsletter Signup");
      document.getElementById("modal-form")!.classList.add("hidden");
      document.getElementById("modal-success")!.classList.remove("hidden");
      setTimeout(closeModal, 2500);
    } catch {
      alert("Something went wrong. Please try again.");
    }
  });
</script>
