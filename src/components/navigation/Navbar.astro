---
const pathname = Astro.url.pathname;

const navItems = [
  { label: "Art News",            href: "/magazine/art-news" },
  { label: "Academia",            href: "/magazine/academia" },
  { label: "Interviews",          href: "/magazine/interviews" },
  { label: "Collecting Now",      href: "/magazine/collecting-now" },
  { label: "African Art History", href: "/magazine/african-art-history" },
  { label: "Exhibitions & Fairs", href: "/magazine/exhibitions-fairs" },
  { label: "Galleries & Museums", href: "/magazine/galleries-museums" },
  { label: "Awards",              href: "/magazine/awards" },
];

function isActive(href: string) {
  return pathname === href || pathname.startsWith(href + "/");
}
---

<header class="sticky top-0 z-50 bg-cotton border-b border-noir/10" role="banner">

  <!-- Row 1: Logo + Search + Subscribe -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-14 md:h-16 gap-4">

      <!-- Full wordmark logo -->
      <a href="/" class="shrink-0 flex items-center focus:outline-none focus-visible:ring-2 focus-visible:ring-lime/60" aria-label="Ncheta Magazine homepage">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 369.09 195.93" class="h-7 md:h-9 w-auto" fill="#181717" role="img" aria-label="Ncheta Magazine">
          <polygon points="49.7 76.59 49.7 116.15 54.39 116.15 54.39 82.12 111.33 116.15 117.28 116.15 117.28 76.59 112.48 76.59 112.48 111.09 55.08 76.59 49.7 76.59"/>
          <path d="M112.48,76.59h4.8v39.56h-6l-56.94-34v34H49.7V76.59h5.38l57.4,34.5Z"/>
          <path d="M157.83,75.63v5A27.62,27.62,0,0,0,146.91,78a14.71,14.71,0,0,0-11.45,4.89q-4.41,4.89-4.4,12.7t4.4,12.64q4.41,4.68,11.81,4.68a30.06,30.06,0,0,0,11.33-2.42v4.66a36.44,36.44,0,0,1-11.69,2.14q-9.22,0-14.92-5.84T126.3,96.06q0-9.91,5.74-16.2a18.93,18.93,0,0,1,14.64-6.28A36.24,36.24,0,0,1,157.83,75.63Z"/>
          <path d="M172.47,52.61v29.1h.18q5.26-8.13,13.85-8.13,7.13,0,11.37,4.57t4.25,12.56v25.72h-4.48V92.49Q197.64,78,186.22,78q-8.17,0-13.75,9v29.46H168V52.61Z"/>
          <path d="M248,93.86H214.87a18.05,18.05,0,0,0-.14,2.2,16,16,0,0,0,5,11.92,16.47,16.47,0,0,0,11.88,4.89q8,0,15.62-6.26v5.07a25.76,25.76,0,0,1-16.17,5.57,19.77,19.77,0,0,1-15-6.3q-5.94-6.3-5.94-16,0-9.22,5.48-15.28a18.73,18.73,0,0,1,27-.59Q248,84.5,248,93.86Zm-32.52-3.61H242.7Q240.32,78,229.4,78a13.29,13.29,0,0,0-8.93,3.23A15.69,15.69,0,0,0,215.47,90.25ZM223.61,58l5.48-1.26,3.33,10.8L230,69.85Z"/>
          <path d="M264.8,60.47V74.4h11.79v3.66H264.8v25q0,6,1,7.92c.66,1.27,2.41,1.9,5.28,1.9a18.57,18.57,0,0,0,7.67-2.06v4.3a19.79,19.79,0,0,1-8.68,2.14,10.34,10.34,0,0,1-6.94-2.37,8.18,8.18,0,0,1-2.79-6.58V78.06H249V74.4h11.33v-10l3.06-3.93Z"/>
          <path d="M320.75,109.12v3.75q-5.81,4.38-8.49,4.38a2.27,2.27,0,0,1-2.15-1,11.53,11.53,0,0,1-.87-4.18q-6.63,5.2-13.16,5.2a11.28,11.28,0,0,1-8-3.1,10,10,0,0,1-3.29-7.54q0-6.85,6.35-10.8t18.14-4.55V85.91q0-8.58-9.32-8.58-5.94,0-12.84,5.34V78.06q7.13-4.49,13.57-4.48a15.12,15.12,0,0,1,9.41,2.81q3.7,2.81,3.7,8.15v26.18c0,1.43.34,2.15,1,2.15C315.62,112.87,317.62,111.62,320.75,109.12Zm-11.51-1V95q-8.64-.33-14.32,3t-5.69,8.57a6.2,6.2,0,0,0,2.38,4.93,8.81,8.81,0,0,0,5.94,2Q303.29,113.55,309.24,108.12Z"/>
          <path d="M220.84,132.88h.87V144.3h-1.36v-8.05l-3.35,5.4h-1.31l-3.35-5.4v8.05H211V132.88h.87l4.5,7.24Z"/>
          <path d="M237.93,144.3h-1.45l-1-2.79H230l-1,2.79h-1.46l4.3-11.42h1.82Zm-3-4-2.23-6-2.23,6Z"/>
