---
import { getNavigationSettings } from "../../sanity/queries";

const pathname = Astro.url.pathname;

let sanityNav = null;
try {
  sanityNav = await getNavigationSettings();
} catch (err) {
  console.warn(
    "Failed to fetch navigation settings from Sanity, using fallback.",
    err,
  );
}

const fallbackNavItems = [
  { label: "Art News", href: "/magazine/art-news" },
  { label: "Academia", href: "/magazine/academia" },
  { label: "Interviews", href: "/magazine/interviews" },
  { label: "Collecting Now", href: "/magazine/collecting-now" },
  { label: "African Art History", href: "/magazine/african-art-history" },
  { label: "Exhibitions & Fairs", href: "/magazine/exhibitions-fairs" },
  { label: "Galleries & Museums", href: "/magazine/galleries-museums" },
  { label: "Awards", href: "/magazine/awards" },
];

let navItems = [];
if (sanityNav && sanityNav.menuItems && sanityNav.menuItems.length > 0) {
  navItems = sanityNav.menuItems.map((item: any) => {
    if (item._type === "categoryLink") {
      const catName = item.category?.name || "Category";
      const catSlug = item.category?.slug?.current || "art-news";
      return {
        label: item.customLabel || catName,
        href: `/magazine/${catSlug}`,
      };
    } else {
      return {
        label: item.label || "Link",
        href: item.url || "#",
      };
    }
  });
} else {
  navItems = fallbackNavItems;
}

function isActive(href: string) {
  return pathname === href || pathname.startsWith(href + "/");
}
---

<header
  class="sticky top-0 z-50 bg-cotton border-b border-noir/10"
  role="banner"
>
  <!-- Row 1: Logo + Search + Subscribe -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 md:h-20 gap-4">
      <!-- Full wordmark logo -->
      <a
        href="/"
        class="shrink-0 flex items-center focus:outline-none focus-visible:ring-2 focus-visible:ring-maroon/60"
        aria-label="Ncheta Magazine homepage"
      >
        <img src="/logo.svg" alt="Ncheta Magazine" class="h-8 md:h-10 w-auto" />
      </a>

      <!-- Right controls -->
      <div class="flex items-center gap-2 md:gap-3">
        <!-- Inline search input (hidden on mobile) -->
        <div class="relative hidden sm:flex items-center">
          <input
            id="nav-search"
            type="search"
            placeholder="Search articles..."
            class="w-44 md:w-56 h-8 pl-3 pr-8 text-xs bg-cotton
                border border-noir/25
                font-inter text-noir
                placeholder:text-noir/30
                focus:outline-none
                focus:border-maroon
                focus:ring-2 focus:ring-maroon/35
                transition-all duration-200"
            aria-label="Search articles"
          />
          <button
            type="button"
            id="nav-search-btn"
            class="absolute right-2 text-noir/40 hover:text-noir transition-colors cursor-pointer"
            aria-label="Submit search"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-3.5 w-3.5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
          </button>
        </div>

        <!-- Subscribe button -->
        <button
          id="subscribe-btn"
          type="button"
          class="h-8 px-4 text-xs font-inter font-medium bg-noir text-cotton
              tracking-wide
              border border-noir
              transition-all duration-200
              hover:bg-lime hover:text-noir hover:border-lime
              focus:outline-none
              focus:ring-2 focus:ring-lime/50
              focus:ring-offset-2 focus:ring-offset-cotton
              disabled:opacity-60 disabled:cursor-not-allowed
              cursor-pointer"
        >
          Subscribe
        </button>

        <!-- Mobile search icon -->
        <button
          type="button"
          id="mobile-search-btn"
          class="sm:hidden p-1.5 text-noir/60 hover:text-noir transition-colors"
          aria-label="Search"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-5 w-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.75"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
        </button>

        <!-- Mobile menu toggle -->
        <details class="lg:hidden group relative">
          <summary
            class="list-none cursor-pointer p-1.5 text-noir/60 hover:text-noir transition-colors"
            aria-label="Toggle menu"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-5 w-5 group-open:hidden"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.75"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-5 w-5 hidden group-open:block"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.75"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          </summary>
          <nav
            class="absolute top-full right-0 w-72 bg-cotton border border-noir/10 shadow-xl z-50"
            aria-label="Mobile navigation"
          >
            <div class="py-2">
              {
                navItems.map((item: any) => {
                  const active = isActive(item.href);
                  return (
                    <a
                      href={item.href}
                      aria-current={active ? "page" : undefined}
                      class:list={[
                        "flex items-center px-5 py-3 font-inter text-sm font-medium transition-colors duration-150 border-l-2",
                        active
                          ? "text-noir border-maroon bg-maroon/10"
                          : "text-noir/65 hover:text-noir hover:bg-noir/5 border-transparent",
                      ]}
                    >
                      {item.label}
                    </a>
                  );
                })
              }
            </div>
          </nav>
        </details>
      </div>
    </div>
  </div>

  <!-- Row 2: Nav links (desktop only) -->
  <div class="hidden lg:block border-t border-noir/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav
        class="flex items-center justify-around"
        aria-label="Primary navigation"
      >
        {
          navItems.map((item: any) => {
            const active = isActive(item.href);
            return (
              <a
                href={item.href}
                aria-current={active ? "page" : undefined}
                class:list={[
                  "relative px-3 py-2.5 font-inter text-[13px] font-medium tracking-wide transition-colors whitespace-nowrap focus:outline-none focus-visible:ring-2 focus-visible:ring-maroon/60 rounded-sm nav-item",
                  active
                    ? "text-noir nav-item--active"
                    : "text-noir/60 hover:text-noir",
                ]}
              >
                {item.label}
              </a>
            );
          })
        }
      </nav>
    </div>
  </div>
</header>

<!-- Subscribe modal -->
<div
  id="subscribe-modal"
  class="fixed inset-0 z-100 hidden items-center justify-center p-4"
  role="dialog"
  aria-modal="true"
  aria-labelledby="modal-title"
>
  <div id="modal-backdrop" class="absolute inset-0 bg-noir/50"></div>
  <div
    class="relative bg-cotton border border-noir/15 shadow-2xl w-full max-w-md p-8 md:p-10"
  >
    <button
      id="modal-close"
      type="button"
      class="absolute top-4 right-4 p-1 text-noir/40 hover:text-noir transition-colors"
      aria-label="Close"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-5 w-5"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="1.75"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
    <h2 id="modal-title" class="font-cinzel font-bold text-2xl text-noir mb-2">
      Stay Informed
    </h2>
    <p class="font-inter text-sm text-noir/60 mb-6 leading-relaxed">
      Weekly curation of the most important stories in African art — delivered
      to your inbox.
    </p>
    <form id="modal-form" class="space-y-3" novalidate>
      <input
        id="modal-email"
        name="email"
        type="email"
        required
        placeholder="your@email.com"
        class="w-full h-10 px-4 bg-cotton
                border border-noir/25
                font-inter text-noir
                placeholder:text-noir/30
                focus:outline-none
                focus:border-maroon
                focus:ring-2 focus:ring-maroon/35
                transition-all duration-200"
      />
      <button
        type="submit"
        class="w-full h-10 bg-noir text-cotton
              font-inter font-medium text-sm tracking-wide
              border border-noir
              transition-all duration-200
              hover:bg-lime hover:text-noir hover:border-lime
              focus:outline-none
              focus:ring-2 focus:ring-lime/50
              focus:ring-offset-2 focus:ring-offset-cotton
              disabled:opacity-60 disabled:cursor-not-allowed
              cursor-pointer"
      >
        Subscribe
      </button>
    </form>
    <div id="modal-success" class="hidden text-center py-4">
      <p class="font-cinzel font-bold text-noir text-lg">You're in.</p>
      <p class="font-inter text-sm text-noir/60 mt-1">
        Check your inbox for a confirmation email.
      </p>
    </div>
  </div>
</div>

<script>
  // Search
  const searchInput = document.getElementById(
    "nav-search",
  ) as HTMLInputElement | null;
  document.getElementById("nav-search-btn")?.addEventListener("click", () => {
    const q = searchInput?.value.trim();
    if (q) window.location.href = `/search?q=${encodeURIComponent(q)}`;
  });
  searchInput?.addEventListener("keydown", (e: KeyboardEvent) => {
    if (e.key === "Enter") {
      const q = (e.target as HTMLInputElement).value.trim();
      if (q) window.location.href = `/search?q=${encodeURIComponent(q)}`;
    }
  });
  document
    .getElementById("mobile-search-btn")
    ?.addEventListener("click", () => {
      window.location.href = "/search";
    });

  // Subscribe modal
  const modal = document.getElementById("subscribe-modal") as HTMLElement;
  const openModal = () => {
    modal.classList.remove("hidden");
    modal.classList.add("flex");
    document.body.style.overflow = "hidden";
    (
      document.getElementById("modal-email") as HTMLInputElement | null
    )?.focus();
  };
  const closeModal = () => {
    modal.classList.add("hidden");
    modal.classList.remove("flex");
    document.body.style.overflow = "";
  };
  document
    .getElementById("subscribe-btn")
    ?.addEventListener("click", openModal);
  document.getElementById("modal-close")?.addEventListener("click", closeModal);
  document
    .getElementById("modal-backdrop")
    ?.addEventListener("click", closeModal);
  document.addEventListener("keydown", (e: KeyboardEvent) => {
    if (e.key === "Escape") closeModal();
  });

  document
    .getElementById("modal-form")
    ?.addEventListener("submit", async (e: SubmitEvent) => {
      e.preventDefault();
      const email = (document.getElementById("modal-email") as HTMLInputElement)
        .value;
      try {
        await fetch("/api/newsletter", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ email }),
        });
        (window as any).umami?.track?.("Newsletter Signup");
        document.getElementById("modal-form")!.classList.add("hidden");
        document.getElementById("modal-success")!.classList.remove("hidden");
        setTimeout(closeModal, 2500);
      } catch {
        alert("Something went wrong. Please try again.");
      }
    });
</script>
