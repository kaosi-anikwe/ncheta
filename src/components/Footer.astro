---
// Footer — multi-column grid with utility links, legal, newsletter
---

<footer class="bg-noir border-t border-white/10 mt-auto">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
      <!-- Brand -->
      <div class="lg:col-span-1">
        <a href="/" class="font-cinzel font-black text-xl text-white">NCHETA</a>
        <p class="mt-3 text-sm text-white/50 leading-relaxed">
          Documenting African art narratives — from historical scholarship to the contemporary market.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="font-cinzel font-bold text-sm text-cotton uppercase tracking-wider mb-4">Navigate</h4>
        <ul class="space-y-2.5">
          <li><a href="/" class="text-sm text-white/60 hover:text-cotton transition-colors">Home</a></li>
          <li><a href="/about" class="text-sm text-white/60 hover:text-cotton transition-colors">About</a></li>
          <li><a href="/services" class="text-sm text-white/60 hover:text-cotton transition-colors">Services</a></li>
          <li><a href="/contact" class="text-sm text-white/60 hover:text-cotton transition-colors">Contact</a></li>
          <li><a href="/resources/search" class="text-sm text-white/60 hover:text-cotton transition-colors">Search</a></li>
        </ul>
      </div>

      <!-- Categories -->
      <div>
        <h4 class="font-cinzel font-bold text-sm text-cotton uppercase tracking-wider mb-4">Categories</h4>
        <ul class="space-y-2.5">
          <li><a href="/magazine/art-news" class="text-sm text-white/60 hover:text-cotton transition-colors">Art News</a></li>
          <li><a href="/magazine/academia" class="text-sm text-white/60 hover:text-cotton transition-colors">Academia</a></li>
          <li><a href="/magazine/interviews" class="text-sm text-white/60 hover:text-cotton transition-colors">Interviews</a></li>
          <li><a href="/magazine/exhibitions-fairs" class="text-sm text-white/60 hover:text-cotton transition-colors">Exhibitions &amp; Fairs</a></li>
          <li><a href="/magazine/african-art-history" class="text-sm text-white/60 hover:text-cotton transition-colors">African Art History</a></li>
        </ul>
      </div>

      <!-- Newsletter -->
      <div>
        <h4 class="font-cinzel font-bold text-sm text-cotton uppercase tracking-wider mb-4">Newsletter</h4>
        <p class="text-sm text-white/50 mb-4">Weekly digest of African art stories.</p>
        <form id="newsletter-form" class="flex gap-2" onsubmit="event.preventDefault(); handleNewsletterSubmit(this);">
          <input
            type="email"
            name="email"
            required
            placeholder="your@email.com"
            class="flex-1 px-3 py-2 text-sm bg-white/5 border border-white/10 rounded text-white placeholder:text-white/30 focus:outline-none focus:border-cherry transition-colors"
          />
          <button type="submit" class="px-4 py-2 text-sm font-medium bg-cherry text-white rounded hover:bg-cherry/80 transition-colors">
            Join
          </button>
        </form>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-6 border-t border-white/5 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-white/30">&copy; {new Date().getFullYear()} Ncheta Magazine. All rights reserved.</p>
      <div class="flex gap-6">
        <a href="/privacy" class="text-xs text-white/30 hover:text-white/50 transition-colors">Privacy</a>
        <a href="/terms" class="text-xs text-white/30 hover:text-white/50 transition-colors">Terms</a>
      </div>
    </div>
  </div>
</footer>

<script>
  async function handleNewsletterSubmit(form: HTMLFormElement) {
    const email = (form.elements.namedItem('email') as HTMLInputElement).value;
    try {
      await fetch('/api/newsletter', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });
      (window as any).umami?.track?.('Newsletter Signup');
      form.innerHTML = '<p class="text-sm text-lime">✓ Subscribed!</p>';
    } catch {
      form.innerHTML = '<p class="text-sm text-red-400">Try again later.</p>';
    }
  }
</script>