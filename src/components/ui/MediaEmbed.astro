---
// MediaEmbed — lite-youtube-embed for video, lazy iframe for podcast
export interface Props {
  youtubeUrl?: string;
  transistorGuid?: string;
}

const { youtubeUrl, transistorGuid } = Astro.props;

// Extract YouTube video ID from URL
function getYouTubeId(url: string): string | null {
  const match = url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/|youtube\.com\/embed\/)([a-zA-Z0-9_-]{11})/);
  return match ? match[1] : null;
}

const videoId = youtubeUrl ? getYouTubeId(youtubeUrl) : null;
---

{youtubeUrl && videoId && (
  <div class="my-8">
    <lite-youtube videoid={videoId} style="background-image: url('https://i.ytimg.com/vi/{videoId}/hqdefault.jpg');">
      <button type="button" class="lty-playbtn">
        <span class="lyt-visually-hidden">Play</span>
      </button>
    </lite-youtube>
  </div>
)}

{transistorGuid && (
  <div class="my-8">
    <iframe
      src={`https://share.transistor.fm/e/${transistorGuid}`}
      width="100%"
      height="180"
      loading="lazy"
      class="rounded-lg border border-white/10"
      title="Podcast Episode"
    ></iframe>
  </div>
)}