---
// Button — variant-driven: Primary, Secondary, Outline, Minimal
export interface Props {
  variant?: "primary" | "secondary" | "outline" | "minimal";
  href?: string;
  type?: "button" | "submit";
  class?: string;
}

const {
  variant = "primary",
  href,
  type = "button",
  class: extraClass = "",
} = Astro.props;

const base =
  "inline-flex items-center justify-center font-inter font-medium transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-maroon/50 rounded";

const variants: Record<string, string> = {
  primary: "px-6 py-3 bg-maroon text-white hover:bg-maroon/85 text-sm",
  secondary: "px-6 py-3 bg-cotton text-noir hover:bg-cotton/85 text-sm",
  outline:
    "px-6 py-3 border border-white/20 text-white hover:border-cotton hover:text-cotton text-sm",
  minimal:
    "px-2 py-1 text-white/60 hover:text-cotton text-sm underline-offset-2 hover:underline",
};

const classes = `${base} ${variants[variant]} ${extraClass}`;
---

{
  href ? (
    <a href={href} class={classes}>
      <slot />
    </a>
  ) : (
    <button type={type} class={classes}>
      <slot />
    </button>
  )
}
