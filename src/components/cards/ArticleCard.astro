---
/**
 * ArticleCard — unified article card component
 *
 * Variants:
 *   "hero"   — Full-width, tall image, large Cinzel title overlaid at bottom.
 *              Used as the lead card in each homepage section.
 *   "medium" — Image on top, Cinzel title + excerpt below.
 *              Used in the 4-small side column and on category pages.
 *   "small"  — Compact: small thumbnail left, title right.
 *              Used in the side stack next to the hero.
 *   "text"   — No image. Category tag + title + author/date inline.
 *              Used for the 4 text articles under each section.
 *
 * All cards: Cotton background, Noir text, Lime on hover.
 */
export interface Props {
  variant?: "hero" | "medium" | "small" | "text";
  title: string;
  excerpt?: string;
  imageUrl?: string;
  imageAlt?: string;
  href: string;
  category?: string;
  author?: string;
  date?: string;
  /** Show a bottom border (for text cards in the row) */
  bordered?: boolean;
}

const {
  variant = "medium",
  title,
  excerpt,
  imageUrl,
  imageAlt,
  href,
  category,
  author,
  date,
  bordered = false,
} = Astro.props;

function fmtDate(d: string | undefined) {
  if (!d) return "";
  return new Date(d).toLocaleDateString("en-US", {
    day: "numeric",
    month: "long",
    year: "numeric",
  });
}
---

{/* ── HERO variant ─ image on top, text block below ────────────── */}
{variant === "hero" && (
  <a
    href={href}
    class="group flex flex-col h-full bg-cotton"
    aria-label={title}
  >
    {/* Image — no overlay, no absolute text */}
    <div class="overflow-hidden aspect-4/3 md:aspect-16/10 lg:aspect-3/2">
      {imageUrl ? (
        <img
          src={imageUrl}
          alt={imageAlt || title}
          class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-700 ease-out"
          loading="eager"
        />
      ) : (
        <div class="w-full h-full transition-opacity duration-300 group-hover:opacity-90" style="background: linear-gradient(135deg, var(--color-noir) 0%, var(--color-maroon) 50%, var(--color-lime) 100%);"></div>
      )}
    </div>

    {/* Text block below the image */}
    <div class="pt-4 pb-2 flex flex-col flex-1">
      {category && (
        <span class="font-inter text-[11px] font-semibold uppercase tracking-widest text-maroon mb-2 block">
          {category}
        </span>
      )}
      <h2 class="font-cinzel font-bold text-xl md:text-2xl lg:text-3xl text-noir leading-snug group-hover:text-maroon transition-colors duration-200">
        {title}
      </h2>
      {excerpt && (
        <p class="mt-3 font-inter text-sm text-noir/55 leading-relaxed">{excerpt}</p>
      )}
      <div class="mt-auto pt-3">
        {(author || date) && (
          <p class="font-inter text-xs text-noir/40">
            {author && <span class="font-medium text-noir/60">{author}</span>}
            {author && date && <span class="mx-1.5">·</span>}
            {date && <time datetime={date}>{fmtDate(date)}</time>}
          </p>
        )}
      </div>
    </div>
  </a>
)}

{/* ── MEDIUM variant ──────────────────────────────────────────── */}
{variant === "medium" && (
  <a
    href={href}
    class="group flex flex-col h-full bg-cotton hover:bg-noir/4 transition-colors duration-200"
    aria-label={title}
  >
    <div class="overflow-hidden aspect-3/2">
      {imageUrl ? (
        <img
          src={imageUrl}
          alt={imageAlt || title}
          class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-500 ease-out"
          loading="lazy"
        />
      ) : (
        <div class="w-full h-full transition-opacity duration-300 group-hover:opacity-90" style="background: linear-gradient(135deg, var(--color-noir) 0%, var(--color-maroon) 50%, var(--color-lime) 100%);"></div>
      )}
    </div>
    <div class="pt-3 pb-5 flex flex-col flex-1">
      {category && (
        <span class="tag-pill mb-1.5 block">{category}</span>
      )}
      <h3 class="font-cinzel font-bold text-base md:text-lg text-noir group-hover:text-maroon transition-colors duration-200 leading-snug">
        {title}
      </h3>
      {excerpt && (
        <p class="mt-2 font-inter text-sm text-noir/55 leading-relaxed">{excerpt}</p>
      )}
      <div class="mt-auto pt-2.5">
        {(author || date) && (
          <p class="mt-2.5 font-inter text-xs text-noir/40">
            {author && <span>{author}</span>}
            {author && date && <span class="mx-1.5 opacity-60">·</span>}
            {date && <time datetime={date}>{fmtDate(date)}</time>}
          </p>
        )}
      </div>
    </div>
  </a>
)}

{/* ── SMALL variant — vertical card for 2×2 grid ───────────────── */}
{variant === "small" && (
  <a
    href={href}
    class="group flex flex-col h-full bg-cotton hover:bg-noir/3 transition-colors duration-200"
    aria-label={title}
  >
    <!-- Image: square aspect for tight grid cells -->
    <div class="overflow-hidden aspect-square">
      {imageUrl ? (
        <img
          src={imageUrl}
          alt={imageAlt || title}
          class="w-full h-full object-cover group-hover:scale-[1.04] transition-transform duration-500"
          loading="lazy"
        />
      ) : (
        <div class="w-full h-full transition-opacity duration-300 group-hover:opacity-90" style="background: linear-gradient(135deg, var(--color-noir) 0%, var(--color-maroon) 50%, var(--color-lime) 100%);"></div>
      )}
    </div>
    <!-- Text block below image -->
    <div class="pt-2.5 pb-1 flex flex-col flex-1">
      {category && (
        <span class="tag-pill mb-1 block">{category}</span>
      )}
      <h4 class="font-cinzel font-bold text-sm text-noir group-hover:text-maroon transition-colors duration-200 leading-snug">
        {title}
      </h4>
      <div class="mt-auto pt-1.5">
        {date && (
          <p class="font-inter text-xs text-noir/35">
            <time datetime={date}>{fmtDate(date)}</time>
          </p>
        )}
      </div>
    </div>
  </a>
)}

{/* ── TEXT variant ────────────────────────────────────────────── */}
{variant === "text" && (
  <a
    href={href}
    class:list={[
      "group flex flex-col h-full py-4 transition-colors duration-200",
      bordered ? "border-b border-noir/10" : "",
    ]}
    aria-label={title}
  >
    {category && (
      <span class="tag-pill mb-1.5 block">{category}</span>
    )}
    <h4 class="font-cinzel font-bold text-sm md:text-base text-noir group-hover:text-maroon transition-colors duration-200 leading-snug">
      {title}
    </h4>
    <div class="mt-auto pt-2">
      {(author || date) && (
        <p class="font-inter text-xs text-noir/40">
          {author && <span>{author}</span>}
          {author && date && <span class="mx-1.5 opacity-60">·</span>}
          {date && <time datetime={date}>{fmtDate(date)}</time>}
        </p>
      )}
    </div>
  </a>
)}
