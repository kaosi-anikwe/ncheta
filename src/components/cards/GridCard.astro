---
// GridCard — reusable post item for dynamic listing grids
export interface Props {
  title: string;
  excerpt?: string;
  imageUrl?: string;
  imageAlt?: string;
  href: string;
  category?: string;
  date?: string;
}

const { title, excerpt, imageUrl, imageAlt, href, category, date } = Astro.props;
---

<a href={href} class="group block bg-white/3 rounded-lg overflow-hidden border border-white/5 hover:border-white/10 transition-all hover:bg-white/5">
  <div class="aspect-16/10 overflow-hidden">
    {imageUrl ? (
      <img
        src={imageUrl}
        alt={imageAlt || title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
        loading="lazy"
      />
    ) : (
      <div class="w-full h-full bg-linear-to-br from-cherry/10 to-maroon/10 flex items-center justify-center">
        <span class="font-cinzel font-bold text-white/10 text-4xl">N</span>
      </div>
    )}
  </div>
  <div class="p-4 md:p-5">
    {category && (
      <span class="inline-block text-xs font-inter font-medium text-cherry uppercase tracking-wider mb-2">
        {category}
      </span>
    )}
    <h3 class="font-cinzel font-bold text-lg md:text-xl text-white group-hover:text-cotton transition-colors leading-snug line-clamp-2">
      {title}
    </h3>
    {excerpt && (
      <p class="mt-2 text-sm text-white/50 line-clamp-2">{excerpt}</p>
    )}
    {date && (
      <p class="mt-3 text-xs text-white/30 font-inter">
        {new Date(date).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
      </p>
    )}
  </div>
</a>