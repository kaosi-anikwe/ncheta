---
// HeroCard — large featured presentation with dominant image and Cinzel display
export interface Props {
  title: string;
  excerpt?: string;
  imageUrl?: string;
  imageAlt?: string;
  href: string;
  category?: string;
}

const { title, excerpt, imageUrl, imageAlt, href, category } = Astro.props;
---

<a href={href} class="group block relative overflow-hidden rounded-lg bg-noir border border-white/5 hover:border-white/10 transition-colors">
  <div class="aspect-video md:aspect-21/9 overflow-hidden">
    {imageUrl ? (
      <img
        src={imageUrl}
        alt={imageAlt || title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
        loading="eager"
      />
    ) : (
      <div class="w-full h-full bg-linear-to-br from-cherry/20 to-maroon/20" />
    )}
  </div>
  <div class="absolute inset-0 bg-linear-to-t from-noir via-noir/40 to-transparent" />
  <div class="absolute bottom-0 left-0 right-0 p-6 md:p-8">
    {category && (
      <span class="inline-block px-3 py-1 text-xs font-inter font-medium bg-cherry text-white rounded-full mb-3">
        {category}
      </span>
    )}
    <h2 class="font-cinzel font-bold text-2xl md:text-4xl lg:text-5xl text-white group-hover:text-cotton transition-colors leading-tight">
      {title}
    </h2>
    {excerpt && (
      <p class="mt-3 text-white/60 text-sm md:text-base line-clamp-2 max-w-2xl">{excerpt}</p>
    )}
  </div>
</a>